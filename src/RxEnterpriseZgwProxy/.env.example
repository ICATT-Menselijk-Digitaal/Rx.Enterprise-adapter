# Rx.Enterprise connection (mTLS)
RxEnterprise__BaseUrl=https://rheden.connect.rx-enterprise-acc.nl
RxEnterprise__CertificatePath=certs/client.crt
RxEnterprise__PrivateKeyPath=certs/client.key

# Clients allowed to call this proxy (e.g. KISS-frontend BFF)
# ID is used as the JWT issuer; SECRET signs the token (min 16 chars)
# These values must match ZAAKSYSTEEM_API_CLIENT_ID / ZAAKSYSTEEM_API_KEY in the KISS-frontend .env
CLIENTS__0__ID=rx-adapter
CLIENTS__0__SECRET=change-me-min-16-chars

# Port this proxy listens on
ASPNETCORE_HTTP_PORTS=8081

# ── KISS-frontend integration ──────────────────────────────────────────────
# Configure the KISS-frontend BFF to use this adapter as a zaaksysteem source
# by adding the following to KISS-frontend/.env.local (adjust register index
# and KLANTINTERACTIE_BASE_URL for your deployment):
#
# REGISTERS__0__IS_DEFAULT=true
# REGISTERS__0__ZAAKSYSTEEM_BASE_URL=http://localhost:8081
# REGISTERS__0__ZAAKSYSTEEM_API_CLIENT_ID=rx-adapter
# REGISTERS__0__ZAAKSYSTEEM_API_KEY=change-me-min-16-chars
# REGISTERS__0__ZAAKSYSTEEM_DEEPLINK_URL=<deeplink-url>
# REGISTERS__0__ZAAKSYSTEEM_DEEPLINK_PROPERTY=identificatie
